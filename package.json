{
  "name": "table-transform",
  "version": "1.0.1",
  "type": "commonjs",
  "description": "Convert tabular data between markdown, CSV, TSV, Excel (xlsx), JSON, and plain text. Includes a CLI and a TypeScript library for reading, writing, and transforming tables.",
  "keywords": [
    "table",
    "csv",
    "tsv",
    "markdown",
    "xlsx",
    "excel",
    "json",
    "convert",
    "transform",
    "cli",
    "typescript",
    "table-transform",
    "convert-table",
    "extract-table",
    "export-table"
  ],
  "author": "Beeno Tung <aabbcc1241@yahoo.com.hk> (https://beeno-tung.surge.sh)",
  "license": "BSD-2-Clause",
  "bin": {
    "table-transform": "bin.js",
    "convert-table": "bin.js",
    "extract-table": "bin.js",
    "export-table": "bin.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "tsc --noEmit",
    "clean": "rimraf dist",
    "build": "rimraf dist && tsc -p . && rimraf dist/tsconfig.tsbuildinfo dist/*.test.d.ts dist/*.test.js dist/*.spec.d.ts dist/*.spec.js",
    "tsc": "tsc -p .",
    "dev": "tsc -p . --watch"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@beenotung/tslib": "^24.26.0",
    "@e965/xlsx": "^0.20.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beenotung/table-transform.git"
  },
  "bugs": {
    "url": "https://github.com/beenotung/table-transform/issues"
  },
  "homepage": "https://github.com/beenotung/table-transform#readme"
}
